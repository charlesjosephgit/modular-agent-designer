# Copy this file to .env and fill in your API keys.
# .env is git-ignored — never commit real secrets.

# Required for Anthropic models (anthropic/...)
ANTHROPIC_API_KEY=

# Required for Google/Gemini models (gemini/...)
GOOGLE_API_KEY=

# Required for OpenAI models (openai/...)
OPENAI_API_KEY=

# Optional: base URL for a local or remote Ollama instance (default: http://localhost:11434)
OLLAMA_API_BASE=http://localhost:11434
